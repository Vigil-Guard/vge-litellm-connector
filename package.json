{
  "name": "vge-litellm-connector",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "sh -c 'docker compose -f tests/e2e/docker-compose.e2e.yml up --build --abort-on-container-exit --exit-code-from e2e; code=$?; docker compose -f tests/e2e/docker-compose.e2e.yml down -v --remove-orphans; exit $code'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.3.0",
    "fastify-metrics": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
