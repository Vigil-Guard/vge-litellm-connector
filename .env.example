# Required
VIGIL_API_URL=https://api.vigilguard.example.com
VIGIL_API_KEY=vg_live_your_key_here

# Optional
ADAPTER_PORT=8081
VIGIL_TIMEOUT_MS=3000
ADAPTER_FAIL_MODE=closed
ADAPTER_INBOUND_BEARER_TOKEN=
LOG_LEVEL=info

# Development/testing only (do not enable in production)
VIGIL_ALLOW_INSECURE_HTTP=false

# LiteLLM (for docker-compose)
LITELLM_MASTER_KEY=sk-litellm-master
# OPENAI_API_KEY=sk-...
