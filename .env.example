# Required
VIGIL_API_URL=https://api.vigilguard.example.com
VIGIL_API_KEY=vg_live_your_key_here

# Optional
ADAPTER_PORT=8081
VIGIL_TIMEOUT_MS=3000
ADAPTER_FAIL_MODE=closed
ADAPTER_INBOUND_BEARER_TOKEN=
LOG_LEVEL=info

# Development/testing only (do not enable in production)
VIGIL_ALLOW_INSECURE_HTTP=false
# NODE_TLS_REJECT_UNAUTHORIZED=0   # bypass self-signed certs (dev only)

# Docker extra_hosts: map VGE hostname to Docker host when VGE runs locally.
# Set to your VGE hostname (default: api.vigilguard).
# VGE_DOCKER_HOST=api.vigilguard

# LiteLLM (for docker-compose)
LITELLM_MASTER_KEY=sk-litellm-master

# LLM Provider keys - set at least one for LiteLLM to proxy requests
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
